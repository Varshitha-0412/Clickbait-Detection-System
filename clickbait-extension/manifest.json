{
  "manifest_version": 3,
  "name": "AI Clickbait Detector",
  "version": "1.0",
  "permissions": ["storage"],
  "host_permissions": ["https://clickbait-detector-api-uxg6.onrender.com/predict"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}