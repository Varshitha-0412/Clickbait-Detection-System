{
  "manifest_version": 3,
  "name": "Neural Clickbait Detector",
  "version": "1.1",
  "permissions": ["storage"],
  "host_permissions": ["https://clickbait-detector-api-uxg6.onrender.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["content.js"]
    }
  ]
}