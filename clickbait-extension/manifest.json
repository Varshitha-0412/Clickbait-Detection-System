{
  "manifest_version": 3,
  "name": "Neural Clickbait Detector",
  "version": "1.0",
  "permissions": ["activeTab"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://twitter.com/*", "https://x.com/*", "https://www.google.com/search*"],
      "js": ["content.js"]
    }
  ]
}